{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/claude_remote_guard.py",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "mcp__remote-dev__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/claude_remote_guard.py",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
